import { useState } from "react";
import { Link } from "react-router";
import SiteNav from "../components/SiteNav";
import SiteFooter from "../components/SiteFooter";
import ContactModal from "../components/ContactModal";

const PILLARS = [
  {
    title: "Know your strengths",
    body: "Good feedback tells you what's working — so you can keep doing it, or do it even better.",
  },
  {
    title: "Fix what's holding you back",
    body: "Bad feedback shows you exactly where you're losing customers — before you lose more of them.",
  },
  {
    title: "Honesty through anonymity",
    body: "No names, no accounts. Just the truth people don't usually say to your face.",
  },
] as const;

const PROOF_POINTS = [
  {
    title: "Free to start",
    body: "Register your shop and start collecting feedback today. No sales call, no credit card.",
  },
  {
    title: "A dashboard that shows the full picture",
    body: "Category breakdowns, monthly trends, and every piece of feedback in one place.",
  },
  {
    title: "A QR code customers actually use",
    body: "Print it at the counter or share it on Telegram — feedback in seconds, no app required.",
  },
  {
    title: "Nothing hidden, nothing locked",
    body: "Your dashboard always shows exactly how much feedback you can see this month, and what upgrading unlocks.",
  },
] as const;

const ROADMAP = [
  {
    title: "Feedback tailored to your business",
    body: "Every business is different. Imagine asking not just about the coffee, but about the security guard at the gate, or the staff walking past at the door — the moments that add up to the experience.",
  },
  {
    title: "Speak it, don't type it",
    body: "Voice as an input — for even less friction, and more honest, in-the-moment feedback.",
  },
  {
    title: "Beyond shops and restaurants",
    body: "Online stores that want to know how delivery felt, or how fast support replied before a sale. SaaS products that want to know why someone almost didn't renew. If people interact with your business, we want to help you hear them.",
  },
] as const;

export default function Business() {
