      <SiteNav howItWorksHref="/welcome#how-it-works" />

      {/* Hero */}
      <div className="max-w-[720px] mx-auto w-full px-4 sm:px-5 md:px-10 pt-14 sm:pt-16 pb-10 text-center">
        <span className="inline-flex items-center gap-1.5 text-xs font-semibold text-[#b1603a] bg-[#f6e7dc] rounded-full px-3.5 py-1.5 mb-6">
          For businesses
        </span>
        <h1 className="font-['Plus_Jakarta_Sans'] text-[30px] sm:text-[42px] font-extrabold text-[#2c2622] tracking-tight leading-[1.1]">
