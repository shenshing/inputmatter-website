      {/* What we're building toward */}
      <div className="max-w-[1120px] mx-auto w-full px-4 sm:px-5 md:px-10 py-10">
        <div className="text-center mb-8">
          <span className="inline-flex items-center gap-1.5 text-xs font-semibold text-[#b1603a] bg-[#f6e7dc] rounded-full px-3.5 py-1.5 mb-4">
