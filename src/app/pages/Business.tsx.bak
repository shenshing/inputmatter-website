          >
            Book a Demo
          </button>
        </div>
      </div>

      {/* Feedback, both ways */}
      <div className="max-w-[1120px] mx-auto w-full px-4 sm:px-5 md:px-10 py-10">
        <h2 className="font-['Plus_Jakarta_Sans'] text-xl sm:text-2xl font-extrabold text-[#2c2622] tracking-tight text-center mb-8">
