              </div>
            ))}
          </div>
        </div>
      </div>

      {/* Built with you */}
      <div className="border-t border-[#f1e8db] bg-[#faf3ea]">
        <div className="max-w-[640px] mx-auto w-full px-4 sm:px-5 md:px-10 py-12 text-center">
          <h2 className="font-['Plus_Jakarta_Sans'] text-xl sm:text-2xl font-extrabold text-[#2c2622] tracking-tight mb-3">
            Built with you
