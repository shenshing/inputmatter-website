                {pillar.title}
              </div>
              <div className="text-[13.5px] text-[#7d7064] leading-relaxed mt-2">
                {pillar.body}
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* What you get today */}
      <div className="border-t border-[#f1e8db]">
        <div className="max-w-[1120px] mx-auto w-full px-4 sm:px-5 md:px-10 py-10">
